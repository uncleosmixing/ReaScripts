    active_slider == 6 ? (slider6 = max(300, min(1200, 300 + ((mouse_x - s_x) / s_w) * 900)); slider_automate(slider6); update_bs2b(););
    active_slider == 7 ? (slider7 = max(1, min(10, 1 + ((mouse_x - s_x) / s_w) * 9)); slider_automate(slider7); update_bs2b(););
    active_slider == 9 ? (slider9 = max(0, min(0.7, ((mouse_x - s_x) / s_w) * 0.7)); slider_automate(slider9); update_itd(););
    active_slider == 11 ? (slider11 = max(-12, min(12, -12 + ((mouse_x - s_x) / s_w) * 24)); slider11 = floor(slider11 * 10) / 10; slider_automate(slider11); );
    active_slider == 2 ? (
