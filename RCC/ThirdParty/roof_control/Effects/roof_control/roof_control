#preset_dir = "roof_control/phones_eq/";

// --- РАСПРЕДЕЛЕНИЕ ПАМЯТИ ---
mem_aura_f = 0;   
mem_aura_s = 200;
mem_subs_L = 600;  
mem_subs_R = 700;
mem_hp_f   = 1000; 
mem_hp_s   = 2000;
gfx_states = 10000; 
num_layers = 9;

mem_fullrange_f = 40000;
//переменные состояния (state)
fr_sL1 = fr_sL2 = fr_sR1 = fr_sR2 = 0;

gmem[3] = slider3;
last_mode = slider3;
gmem[6] = slider1;     
last_gmem4 = slider1;   
last_bypass = slider1;  

// --- CROSSFEED DELAY BUFFER ---
cf_bufsize = 1024; // степень двойки
cf_bufmask = cf_bufsize - 1;

cf_bufL = 30000;
cf_bufR = cf_bufL + cf_bufsize;

cf_writepos = 0;

#hp_preset_name = "";
#current_fn = ""; 

b_gain = 10^(slider2 / 20);
p_gain;
scroll_pos = 0;
scroll_dir = 1;
last_scroll_time = time_precise();
canvas_w = 1280; canvas_h = 698;
is_config_open = 0;
sl_trim = 2.302585092994045684;
hp_need_reload = 1;
fade_state = 0; //0:nofade 1:fadeout 2:switchmode 3:fadein
fade = 1;
fade_step = 0.006;
mode = slider3;
active_slider = 0;

function save_profile()
(
  gmem[0] = 3;
  gmem[7] = slider11;

  i = 0;
  loop(256,
    ch = str_getchar(#current_fn, i);
    gmem[10 + i] = ch;
    ch == 0 ? break;
    i += 1;
  );
);

function cf_read(buf, pos, delay_int, delay_frac)
(
  idx1 = (pos - delay_int) & cf_bufmask;
  idx2 = (idx1 - 1) & cf_bufmask;
  s1 = buf[idx1];
  s2 = buf[idx2];
  s1 + (s2 - s1) * delay_frac;
);

function reset_states()
(
  memset(mem_aura_s, 0, 400);
  memset(mem_subs_L, 0, 100);
  memset(mem_subs_R, 0, 100);
  memset(mem_hp_s, 0, 2048);
  ph_sL1 = ph_sL2 = ph_sR1 = ph_sR2 = 0;
  vi_sL1 = vi_sL2 = vi_sR1 = vi_sR2 = 0;
  sl_lastL = sl_lastR = 0;
  loL = loR = hiL = hiR = asisL = asisR = 0;
  memset(cf_bufL, 0, cf_bufsize * 2);
  cf_writepos = 0;
  fr_sL1 = fr_sL2 = fr_sR1 = fr_sR2 = 0;
);

function setup_biquad_to_mem(mem_base, idx, f, g, q, type)
(
  f = max(1, min(f, srate * 0.49)); 
  q = max(0.001, q);
  w0 = 2 * $pi * f / srate; 
  cosw = cos(w0); 
  sinw = sin(w0);

  type == 0 ? ( // PEAK
    A = sqrt(10^(g/20));
    alpha = sinw / (2 * q);
    
    b0 = 1 + alpha * A; b1 = -2 * cosw; b2 = 1 - alpha * A;
    a0 = 1 + alpha / A; a1 = -2 * cosw; a2 = 1 - alpha / A;
  ) : 
  (type == 1 || type == 2) ? ( // SHELVING (1: Low / 2: High)
    A = 10^(g/40);
    // Эталонная альфа
    alpha = (sinw / 2) * sqrt( (A + 1/A) * (1/q - 1) + 2 );
    type == 1 ? ( // LOW SHELF
      b0 = A*((A+1)-(A-1)*cosw+2*sqrt(A)*alpha); 
      b1 = 2*A*((A-1)-(A+1)*cosw); 
      b2 = A*((A+1)-(A-1)*cosw-2*sqrt(A)*alpha);
      a0 = (A+1)+(A-1)*cosw+2*sqrt(A)*alpha; 
      a1 = -2*((A-1)+(A+1)*cosw); 
      a2 = (A+1)+(A-1)*cosw-2*sqrt(A)*alpha;
    ) : ( // HIGH SHELF
      b0 = A*((A+1)+(A-1)*cosw+2*sqrt(A)*alpha); 
      b1 = -2*A*((A-1)+(A+1)*cosw); 
      b2 = A*((A+1)+(A-1)*cosw-2*sqrt(A)*alpha);
      a0 = (A+1)-(A-1)*cosw+2*sqrt(A)*alpha; 
      a1 = 2*((A-1)-(A+1)*cosw); 
      a2 = (A+1)-(A-1)*cosw-2*sqrt(A)*alpha;
    );
  ) : ( // PASS FILTERS (3: HP / 4: LP)
    alpha = sinw / (2 * q);
    type == 3 ? ( // HPF
      b0 = (1 + cosw) / 2; b1 = -(1 + cosw); b2 = (1 + cosw) / 2;
      a0 = 1 + alpha; a1 = -2 * cosw; a2 = 1 - alpha;
    ) : ( // LPF
      b0 = (1 - cosw) / 2; b1 = 1 - cosw; b2 = (1 - cosw) / 2;
      a0 = 1 + alpha; a1 = -2 * cosw; a2 = 1 - alpha;
    );
  );

  p = mem_base + idx * 5; 
  ai = 1 / a0;
  p[0] = b0 * ai; p[1] = b1 * ai; p[2] = b2 * ai; p[3] = a1 * ai; p[4] = a2 * ai;
);

function update_bs2b()
(
  GB_lo = slider7*(-5/6)-3; GB_hi = slider7*(1/6)-3;
  G_lo = 10^(GB_lo/20); G_hi = 1 - 10^(GB_hi/20);
  Fc_lo = slider6; Fc_hi = Fc_lo * 2^((GB_lo - 20*log(G_hi)/log(10))/12);
  x = exp(-2*$pi*Fc_lo/srate); b1_lo = x; a0_lo = G_lo*(1-x);
  x = exp(-2*$pi*Fc_hi/srate); b1_hi = x; a0_hi = 1 - G_hi*(1-x); a1_hi = -x;
  gain_cf = 1 / (1 - G_hi + G_lo);
);

function update_params()
(
  v_ov = srate/44100;
  p_f = 0.1245 / v_ov; p_r = 0.46; p_K = tan($pi * p_f); p_n = 1.0 / (1.0 + p_K / p_r + p_K * p_K);
  ph_a0 = p_K / p_r * p_n; ph_a1 = 0; ph_a2 = -ph_a0; ph_b1 = 2.0 * (p_K * p_K - 1.0) * p_n; ph_b2 = (1.0 - p_K / p_r + p_K * p_K) * p_n;
  v_f=0.0385/v_ov; v_r=0.0825; v_K=tan($pi*v_f); v_n=1/(1+v_K/v_r+v_K*v_K);
  vi_a0=v_K/v_r*v_n; vi_a2=-vi_a0; vi_b1=2*(v_K*v_K-1)*v_n; vi_b2=(1-v_K/v_r+v_K*v_K) * v_n;
  sub_iirAmount=(2250/44100)/v_ov;
  na=0;
  setup_biquad_to_mem(mem_aura_f,na,130,0,0.707,3); na+=1;
  setup_biquad_to_mem(mem_aura_f,na,130,0,0.707,3); na+=1;
  setup_biquad_to_mem(mem_aura_f,na,130,0,0.707,3); na+=1;
  setup_biquad_to_mem(mem_aura_f,na,14207,1.9,4.22,0); na+=1;
  setup_biquad_to_mem(mem_aura_f,na,853,2.2,4.749,0); na+=1;
  setup_biquad_to_mem(mem_aura_f,na,6826,3.1,4.17,0); na+=1;
  setup_biquad_to_mem(mem_aura_f,na,10762,3,4.01,0); na+=1;
  setup_biquad_to_mem(mem_aura_f,na,12390,2.8,3.65,0); na+=1;
  setup_biquad_to_mem(mem_aura_f,na,3412,-0.8,1,0); na+=1;
  setup_biquad_to_mem(mem_aura_f,na,1836,2.5,2.55,0); na+=1;
  setup_biquad_to_mem(mem_aura_f,na,7693,5.7,1.79,0); na+=1;
  setup_biquad_to_mem(mem_aura_f,na,517,-0.9,3.397,0); na+=1;
  setup_biquad_to_mem(mem_aura_f,na,387,-0.9,2.57,0); na+=1;
  setup_biquad_to_mem(mem_aura_f,na,7850,-11.8,0.7,2); na+=1;
  setup_biquad_to_mem(mem_aura_f,na,7850,0,0.707,4); na+=1;
  setup_biquad_to_mem(mem_aura_f,na,7850,0,0.707,4); na+=1;
  _num_aura=na; 
  update_bs2b();
);

function update_itd()
(
cf_delay_spl = slider9 * srate * 0.001;
cf_delay_int = floor(cf_delay_spl);
cf_delay_frac = cf_delay_spl - cf_delay_int;
);

update_params();
setup_biquad_to_mem(mem_fullrange_f, 0, 200, 0, 0.707, 3); // HPF for fullrange
update_itd()

@slider

b_gain = 10^(slider2 / 20);

slider6 != last_cf_cutoff || slider7 != last_cf_sup || slider5 != last_cf_state ? ( 
  update_bs2b(); 
  last_cf_cutoff = slider6; last_cf_sup = slider7; last_cf_state = slider5;
);
slider1 != last_bypass ? ( memset(mem_hp_s, 0, 2048); last_bypass = slider1; );
slider8 != last_hp_index ? ( last_hp_index = slider8; hp_need_reload = 1; );
slider3 != last_mode ? (
  fade_state = 1;
  last_mode = slider3;
  update_itd();
);

@block
srate!=last_srate ? ( last_srate=srate; update_params(); hp_need_reload = 1 );
gmem[2] == 2 ? ( gmem[2] = 0; hp_need_reload = 1; );

// --- УМНАЯ СИНХРОНИЗАЦИЯ (v2.0) ---

// 1. Приоритет внешнему управлению (Тулбар/Бубрик)
gmem[3] != last_gmem3 ? (
    slider3 = gmem[3];
    slider4 = 0;
    last_mode = slider3;
    last_gmem3 = gmem[3];
    fade_state = 1; // Запускаем фейд
    slider_automate(slider3);
    slider_automate(slider4);
);

gmem[4] == 1 && gmem[3] == slider3 && slider4 == 1 ? (
    slider4 = 0;
    slider_automate(slider4);
);

// 2. Изменение режима из интерфейса
slider3 != last_mode ? (
    gmem[3] = slider3;
    last_gmem3 = slider3;
    last_mode = slider3;
);

// 3. Удаленное управление байпасом (через gmem[4])
gmem[6] != last_gmem4 ? (
    slider1 = gmem[6];         // Устанавливаем байпас из внешней памяти
    last_bypass = slider1;     // Синхронизиро
    last_gmem4 = gmem[6];      // Обновляем состояние gmem
    fade_state = 1;            
    slider_automate(slider1);  
);

// 4. Обратная связь
slider1 != last_bypass ? (
    gmem[6] = slider1;
    last_gmem4 = slider1;
    last_bypass = slider1;
);


hp_need_reload ? (
  hp_need_reload = 0; hp_num_filters = 0; hp_preamp_db = 0; scroll_pos = 0;
  f_db = file_open(#db_path);
  
  #current_fn = "";
  
  f_db > 0 ? (
    i = 0;
    while(file_string(f_db, #line) > 0) (
      i == slider8 ? (
        strcpy(#current_fn, #line);
        
        // --- ОЧИСТКА ПЕРЕНОСОВ СТРОК (\r, \n) ---
        _len = strlen(#current_fn);
        while(_len > 0 && (
          str_getchar(#current_fn, _len-1) == 10 || // \n
          str_getchar(#current_fn, _len-1) == 13    // \r
        )) (
          _len -= 1;
          str_setchar(#current_fn, _len, 0);
        );
        // ----------------------------------------------
      );
      i += 1;
    );
    file_close(f_db);
    num_total_presets = i;
  );

  strlen(#current_fn) > 0 ? (
    // --- ОТОБРАЖАЕМОЕ ИМЯ ---
    strcpy(#hp_preset_name, #current_fn);
    _dot_pos = -1;
    _i = 0;
    _p_len = strlen(#hp_preset_name);
    loop(_p_len,
      str_getchar(#hp_preset_name, _i) == '.' ? _dot_pos = _i;
      _i += 1;
    );
    _dot_pos >= 0 ? str_setchar(#hp_preset_name, _dot_pos, 0);
    // ------------------------------------------

    #full_path = "roof_control/phones_eq/";
    strcat(#full_path, #current_fn);
    
    f_hp = file_open(#full_path);
    f_hp > 0 ? (
      while(file_string(f_hp, #line_hp) > 0) (
        match("*Preamp: %f*", #line_hp, slider11) ? (
          p_gain = slider11;
        );
        match("*PK*Fc %f*Gain %f*Q %f*", #line_hp, f, g, q) ? ( 
          setup_biquad_to_mem(mem_hp_f, hp_num_filters, f, g, q, 0); 
          hp_num_filters += 1; 
        ) :
        match("*LSC*Fc %f*Gain %f*Q %f*", #line_hp, f, g, q) ? ( 
          setup_biquad_to_mem(mem_hp_f, hp_num_filters, f, g, q, 1); 
          hp_num_filters += 1; 
        ) :
        match("*HSC*Fc %f*Gain %f*Q %f*", #line_hp, f, g, q) ? ( 
          setup_biquad_to_mem(mem_hp_f, hp_num_filters, f, g, q, 2); 
          hp_num_filters += 1; 
        );
      );
      file_close(f_hp);
    ) : ( 
      #hp_preset_name = " Err: File missing "; 
    );
  ) : ( 
    #hp_preset_name = " No Preset "; 
  );
);

@sample
// 1. Обработка фейда
fade_state == 1 ? ( fade -= fade_step; fade <= 0 ? ( fade = 0; fade_state = 2; ); );
fade_state == 2 ? ( mode = slider3; reset_states(); fade_state = 3; );
fade_state == 3 ? ( fade += fade_step; fade >= 1 ? ( fade = 1; fade_state = 0; ); );

// 2. Проверка внутреннего байпаса
slider1 == 1 ? ( 
  spl0 *= b_gain; 
  spl1 *= b_gain; 
) : (
  // 3. Выбор режима моделирования
  slider4 == 0 ? (
  mode == 1 ? ( // Subwoofer
    sL=spl0*1.42; sR=spl1*1.42; sg=((1.42-1)*0.75)+1; si=0;
    loop(25,
      mem_subs_L[si]=(mem_subs_L[si]*(1-sub_iirAmount))+(sL*sub_iirAmount); sL=mem_subs_L[si];
      mem_subs_R[si]=(mem_subs_R[si]*(1-sub_iirAmount))+(sR*sub_iirAmount); sR=mem_subs_R[si];
      sL*=sg; sR*=sg; sg=((sg-1)*0.75)+1; sL=max(-1,min(1,sL)); sR=max(-1,min(1,sR)); si+=1;
    );
    mem_subs_L[25]=(mem_subs_L[25]*(1-sub_iirAmount))+(sL*sub_iirAmount);
    mem_subs_R[25]=(mem_subs_R[25]*(1-sub_iirAmount))+(sR*sub_iirAmount);
    spl0=max(-1,min(1,mem_subs_L[25])); spl1=max(-1,min(1,mem_subs_R[25]));
  ) :
  mode == 2 ? ( // Transient Monitor (Slew)
    slL = (spl0 - sl_lastL) * sl_trim; slR = (spl1 - sl_lastR) * sl_trim; 
    sl_lastL = spl0; sl_lastR = spl1;
    spl0 = max(-1,min(1,slL)); spl1 = max(-1,min(1,slR));
  ) :
 mode == 3 ? ( // Auracube
     as0 = spl0; as1 = spl1; ai = 0;
     loop(_num_aura,
       ap = mem_aura_f + ai*5; 
       as_p = mem_aura_s + ai*4;
 
       // Левый канал
       aoutL = as0 * ap[0] + as_p[0];
       as_p[0] = as0 * ap[1] - aoutL * ap[3] + as_p[1];
       as_p[1] = as0 * ap[2] - aoutL * ap[4];
       as0 = aoutL;
 
       // Правый канал
       aoutR = as1 * ap[0] + as_p[2];
       as_p[2] = as1 * ap[1] - aoutR * ap[3] + as_p[3];
       as_p[3] = as1 * ap[2] - aoutR * ap[4];
       as1 = aoutR; 
       
       ai += 1;
     );
     spl0 = as0; spl1 = as1;
  ) :
  mode == 4 ? ( // Smartphone
    mono = (spl0 + spl1) * 0.5; inL = sin(mono); inR = sin(mono);
    outL = (inL * ph_a0) + ph_sL1; ph_sL1 = (inL * ph_a1) - (outL * ph_b1) + ph_sL2; ph_sL2 = (inL * ph_a2) - (outL * ph_b2);
    outR = (inR * ph_a0) + ph_sR1; ph_sR1 = (inR * ph_a1) - (outR * ph_b1) + ph_sR2; ph_sR2 = (inR * ph_a2) - (outR * ph_b2);
    spl0 = asin(max(-1,min(1,outL))); spl1 = asin(max(-1,min(1,outR)));
  ) :
  mode == 5 ? ( // Vinyl
    inL = sin(spl0); inR = sin(spl1);
    vL = (inL * vi_a0) + vi_sL1; vi_sL1 = (-vL * vi_b1) + vi_sL2; vi_sL2 = (inL * vi_a2) - (vL * vi_b2);
    vR = (inR * vi_a0) + vi_sR1; vi_sR1 = (-vR * vi_b1) + vi_sR2; vi_sR2 = (inR * vi_a2) - (vR * vi_b2);
    spl0 = asin(max(-1,min(1,vL))); spl1 = asin(max(-1,min(1,vR)));
  ) :
 mode == 6 ? ( 
       origL = spl0; origR = spl1;
       
       // Генерация Саба
       sL = origL * 1.42; sR = origR * 1.42; 
       sg = ((1.42-1)*0.75)+1; si = 0;
       loop(25,
         mem_subs_L[si] = (mem_subs_L[si] * (1 - sub_iirAmount)) + (sL * sub_iirAmount); sL = mem_subs_L[si];
         mem_subs_R[si] = (mem_subs_R[si] * (1 - sub_iirAmount)) + (sR * sub_iirAmount); sR = mem_subs_R[si];
         sL *= sg; sR *= sg; sg = ((sg - 1) * 0.75) + 1; 
         sL = max(-1, min(1, sL)); sR = max(-1, min(1, sR)); si += 1;
       );
       // 26-й каскад
       sL_final = (mem_subs_L[25] * (1 - sub_iirAmount)) + (sL * sub_iirAmount);
       sR_final = (mem_subs_R[25] * (1 - sub_iirAmount)) + (sR * sub_iirAmount);
       mem_subs_L[25] = sL_final; mem_subs_R[25] = sR_final;
 
       // Фильтрация оригинала
       hp = mem_fullrange_f;
       
       // Левый верх
       hpL = origL * hp[0] + fr_sL1;
       fr_sL1 = origL * hp[1] - hpL * hp[3] + fr_sL2;
       fr_sL2 = origL * hp[2] - hpL * hp[4];
 
       // Правый верх
       hpR = origR * hp[0] + fr_sR1;
       fr_sR1 = origR * hp[1] - hpR * hp[3] + fr_sR2;
       fr_sR2 = origR * hp[2] - hpR * hp[4];
 
       // Смешиваем
       spl0 = (hpL + sL_final);
       spl1 = (hpR + sR_final);
   );

  // 4. Кроссфид
  (slider5 == 0 && (mode == 0 || mode == 3 || mode == 5 || mode == 6)) ? (
    inL = spl0; inR = spl1; 
    loL = a0_lo*inL + b1_lo*loL; loR = a0_lo*inR + b1_lo*loR;
    tmpHiL = a0_hi*inL + a1_hi*asisL + b1_hi*hiL; 
    tmpHiR = a0_hi*inR + a1_hi*asisR + b1_hi*hiR;
    asisL = inL; asisR = inR; hiL = tmpHiL; hiR = tmpHiR; 
    
    cf_bufL[cf_writepos] = loL;
    cf_bufR[cf_writepos] = loR;
    
